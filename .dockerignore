# Build context for ./Dockerfile. The image builds the source tree itself, so
# nothing under src/ or public/ may be excluded here — keep only build artifacts
# and local junk out of the context.
**/node_modules
.next
out
.git
.github
test-results
playwright-report
storybook-static
*.log
.DS_Store
# Local env files carry secrets (e.g. CLERK_SECRET_KEY) — keep them out of the
# build context so a local `docker compose build` never bakes them into layers.
.env*
