{
  "name": "goals-mcp-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-migrations.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server/src/index.js",
    "dev": "npm run build && node --watch dist/server/src/index.js",
    "test": "npm run build && node --test --test-concurrency=1 dist/server/test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.5",
    "typescript": "^5.9.3"
  }
}
